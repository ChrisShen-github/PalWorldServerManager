# Public port for the management panel.
PMSM_HTTP_PORT=8080

# Start with the dashboard's deterministic sample data. Set to false once the
# native SteamCMD server has its REST API configured.
PMSM_DEMO_MODE=true

# The Palworld server runs natively on the Ubuntu host. Docker resolves this
# hostname through the host-gateway mapping declared in compose.yaml.
PALWORLD_REST_URL=http://host.docker.internal:8212
PALWORLD_REST_USERNAME=admin
# Never commit the real admin password. Put it in .env on the Ubuntu host.
PALWORLD_REST_PASSWORD=
