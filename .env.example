# Public port for the management panel.
PMSM_HTTP_PORT=8080

# Start with the dashboard's deterministic sample data. Set to false once the
# palworld-server Compose profile is running and REST API is configured.
PMSM_DEMO_MODE=true

# The manager resolves this address from inside its Compose network.
PALWORLD_REST_URL=http://palworld-server:8212
PALWORLD_REST_USERNAME=admin
# Never commit the real admin password. Put it in .env on the Ubuntu host.
PALWORLD_REST_PASSWORD=

# Pin the official image before upgrading. Back up saves before changing it.
PALWORLD_IMAGE_TAG=v1.0.1.100619
PALWORLD_GAME_PORT=8211
PALWORLD_REST_PORT=8212
